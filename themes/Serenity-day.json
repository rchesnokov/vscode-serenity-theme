{
  "tokenColors": [
    {
      "name": "Class",
      "scope": [
        "constant.character.escape",
        "entity.name.class",
        "entity.name.type.class",
        "new.expr",
        "meta.block",
        "meta.class",
        "meta.function-call",
        "meta.var.expr",
        "support.type",
        "support.class",
        "markup.changed.git_gutter"
      ],
      "settings": {
        "foreground": "#00c099"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.block",
        "punctuation.definition.comment",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#91a1c5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.undefined",
        "constant.numeric.scss",
        "support.constant",
        "constant.character",
        "entity.name.tag.css",
        "entity.name.tag.scss",
        "entity.name.tag.less"
      ],
      "settings": {
        "foreground": "#cf005a"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function",
        "keyword.other.special-method",
        "meta.function-call",
        "meta.block-level",
        "keyword.operator.typeof",
        "keyword.operator.module"
      ],
      "settings": {
        "foreground": "#565eaa"
      }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "entity.name.tag.other", "entity.name.tag.reference.scss"],
      "settings": {
        "foreground": "#c96999",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Object property",
      "scope": [
          "class.declaration",
          "variable.other.constant.property",
          "variable.other.property",
          "variable.other.object.property",
        	"meta.object-literal.key.tsx",
          "meta.object.member.tsx",
          "meta.objectliteral.tsx",
          "meta.object.member.tsx",
          "meta.objectliteral.tsx",
          "meta.export.default.tsx",
          "entity.other.attribute-name.generic"
      ],
      "settings": {
        "foreground": "#5c7995",
        "fontStyle": ""
      }
    },
    {
      "name": "Operator",
      "scope": [
        "punctuation.accessor.optional",
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.relational",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.compartion",
        "constant.other.color"
      ],
      "settings": {
        "foreground": "#520085",
        "fontStyle": ""
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "meta.parameters",
        "variable.parameter.tsx",
        "variable.scss"
      ],
      "settings": {
        "foreground": "#7d50ad"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.section.embedded",
        "punctuation.other",
        "punctuation.definition",
        "punctuation.definition.block",
        "punctuation.section.property-list",
        "punctuation.separator",
        "punctuation.section.tag",
        "meta.delimiter",
        "meta.group.braces",
        "meta.brace.round",
        "meta.brace.square",
        "keyword.operator.accessor"
      ],
      "settings": {
        "foreground": "#9ba8dd"
      }
    },
    {
      "name": "Storage & Units",
      "scope": [
        "storage",
        "storage.modifier",
        "variable.language",
        "keyword.operator.new",
        "keyword.other.substitution",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "entity.other.attribute-name.pseudo-element",
        "entity.other.attribute-name.pseudo-class",
        "punctuation.definition.generic"
      ],
      "settings": {
        "foreground": "#776eaa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.interpolated",
        "punctuation.definition.string",
        "punctuation.definition.entity",
        "meta.attribute-selector.scss"
      ],
      "settings": {
        "foreground": "#86692e"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type", 
        "support.type.primitive", 
        "meta.type.parameters", 
        "variable.object.property", 
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#cb8296",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable.other.constant",
        "variable.other.object",
        "variable.other.readwrite",
        "object.key",
        "string.unquoted",
        "meta.arguments",
        "meta.property.object",
        "meta.jsx.children",
        "meta.jsx.js"
      ],
      "settings": {
        "foreground": "#505275"
      }
    },
    {
      "name": "Component",
      "scope": [
        "support.class.component"
      ],
      "settings": {
        "foreground": "#cb0058"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#720000"
      }
    },
    {
      "name": "Component/Tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.definition.tag.tsx",
        "punctuation.definition.tag.begin.tsx",
        "punctuation.definition.tag.end.tsx",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#e60051"
      }
    },
    {
      "name": "Component/Tag attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute-with-value.id.html",
        "entity.other.attribute-name.id.html",
        "meta.attribute-with-value.class.html",
        "entity.other.attribute-name.class.html",
        "meta.attribute-with-value.html",
        "entity.other.attribute-name.html",
        "entity.name.tag.reference"
      ],
      "settings": {
        "foreground": "#b55476"
      }
    },
    {
      "name": "CSS property value",
      "scope": ["support.constant.property-value", "constant.property-value"],
      "settings": {
        "foreground": "#595899"
      }
    },
    {
      "name": "CSS class",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.parent-selector-suffix",
        "entity.other.attribute-name.parent-selector-suffix.css",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#1a50bb"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "entity.other.attribute-name.generic",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#6c799b"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp",
        "string.regexp keyword.operator",
        "constant.character.escape.backslash.regexp",
        "keyword.control.anchor.regexp",
        "keyword.other.unit",
        "constant.other.unit"
      ],
      "settings": {
        "foreground": "#5f9bc0"
      }
    }
  ],
  "colors": {
    "activityBar.background": "#3f454e",
    "activityBar.foreground": "#999",
    "activityBarBadge.background": "#ca970b",
    "activityBarBadge.foreground": "#222222",
    "breadcrumb.activeSelectionForeground": "#ca970b",
    "breadcrumb.background": "#d7dfea",
    "breadcrumb.foreground": "#8992bb",
    "breadcrumbPicker.background": "#e4e9f0",
    "button.background": "#556889",
    "button.foreground": "#99d6ff",
    "dropdown.background": "#c7d5ee",
    "dropdown.listBackground": "#e4e9f0",
    "editor.background": "#e4e9f0",
    "editor.foreground": "#4c4473",
